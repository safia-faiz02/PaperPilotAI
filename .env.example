# This file is a TEMPLATE showing which settings our app needs.
# Copy this file, rename the copy to ".env" (no "example"), and that's
# the file Docker actually reads. We keep .env.example checked into the
# project so anyone (including future-you) knows what's needed, while the
# real .env (with real values) stays out of git — see .gitignore.

POSTGRES_USER=paperpilot
POSTGRES_PASSWORD=paperpilot_dev_password
POSTGRES_DB=paperpilot
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# POSTGRES_HOST is "postgres" — not "localhost" — because inside Docker,
# containers reach each other using the SERVICE NAME from docker-compose.yml
# as if it were a hostname. Our postgres container is literally named
# "postgres" in docker-compose.yml, so that's how our api container finds it.

REDIS_HOST=redis
REDIS_PORT=6379

SECRET_KEY=your-super-secret-key-change-this-in-production-make-it-long-and-random
ACCESS_TOKEN_EXPIRE_MINUTES=30
# Same idea as POSTGRES_HOST: "redis" is the service name we'll give the
# Redis container in docker-compose.yml, so that's the hostname our api
# container uses to reach it.
