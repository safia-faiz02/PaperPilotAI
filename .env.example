# This file is a TEMPLATE showing which settings the backend needs.
# Copy this file, rename the copy to ".env" (no "example"), fill in your
# own values, and that's the file Docker actually reads. .env.example
# stays in git so anyone (recruiters, collaborators, future-you on a new
# machine) knows exactly what's required to run the project; the real
# .env with real secrets never gets committed — see .gitignore.

POSTGRES_USER=paperpilot
POSTGRES_PASSWORD=paperpilot_dev_password
POSTGRES_DB=paperpilot
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# POSTGRES_HOST is "postgres" — not "localhost" — because inside Docker,
# containers reach each other using the SERVICE NAME from docker-compose.yml
# as if it were a hostname. Our postgres container is literally named
# "postgres" in docker-compose.yml, so that's how our api container finds it.

REDIS_HOST=redis
REDIS_PORT=6379
# Same idea as POSTGRES_HOST: "redis" is the service name of the Redis
# container in docker-compose.yml.

SECRET_KEY=your-super-secret-key-change-this-in-production-make-it-long-and-random
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Comma-separated list of origins allowed to call this API from a browser
# (not needed for the Streamlit frontend itself, which calls the API
# server-side, but required for any browser-based client).
CORS_ORIGINS=http://localhost:8501

# Qdrant vector database
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=papers

# Groq — free LLM API for the synthesis agent
# Get your free key at https://console.groq.com
# Free tier: 14,400 requests/day, ~0.5s response time
GROQ_API_KEY=

# LangSmith (optional) — traces every LangChain/LangGraph call (prompt,
# LLM call, each node in the synthesis graph) automatically once enabled.
# LangChain reads these env vars itself; no code changes needed. Leave
# LANGCHAIN_TRACING_V2 as false if you don't want to set this up — the
# app works identically either way, this only adds observability.
# Get a free key at https://smith.langchain.com -> Settings -> API Keys
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=paperpilot
